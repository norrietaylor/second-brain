#!/bin/bash
# granola-batch-resync — Re-sync Granola meetings in batches to avoid rate limits
#
# Usage:
#   granola-batch-resync                    — delete 5 files, prompt to sync
#   granola-batch-resync --batch-size 10    — delete 10 files per batch
#   granola-batch-resync --status           — show remaining files
#   granola-batch-resync --all              — delete all and prompt (use with caution)
#
# Workflow:
#   1. Run this script to delete a batch of staged files
#   2. Click "Sync Now" in the Granola plugin settings (Obsidian)
#   3. Wait for sync to complete (watch for rate limit errors in console)
#   4. Repeat until all files are re-synced
#
# This is designed for initial library import when you need transcripts
# but can't fetch them all at once due to API rate limits.

set -euo pipefail

VAULT="${SECOND_BRAIN_VAULT:-$HOME/Documents/obsidian/second-brain}"
CONFIG_FILE="$VAULT/05 Meta/config.yaml"

# Read staging folder from config
STAGING_FOLDER=$(awk '
    /^granola:/ { in_granola=1; next }
    in_granola && /^[a-zA-Z]/ && !/^[[:space:]]/ { in_granola=0 }
    in_granola && /staging_folder:/ {
        sub(/^[[:space:]]*staging_folder:[[:space:]]*/, "")
        gsub(/"/, "")
        print
        exit
    }
' "$CONFIG_FILE" 2>/dev/null || true)
STAGING_FOLDER="${STAGING_FOLDER:-Granola}"
STAGING_DIR="$VAULT/$STAGING_FOLDER"

BATCH_SIZE=5
MODE="batch"

# Parse args
while [ $# -gt 0 ]; do
    case "$1" in
        --batch-size)
            BATCH_SIZE="$2"
            shift 2
            ;;
        --status)
            MODE="status"
            shift
            ;;
        --all)
            MODE="all"
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

# Check staging folder
if [ ! -d "$STAGING_DIR" ]; then
    echo "No staging folder at $STAGING_DIR"
    exit 0
fi

# Collect files
FILES=()
for file in "$STAGING_DIR"/*.md; do
    [ -f "$file" ] || continue
    FILES+=("$file")
done

TOTAL=${#FILES[@]}

if [ "$TOTAL" -eq 0 ]; then
    echo "No files in staging folder. Nothing to re-sync."
    exit 0
fi

# Status mode
if [ "$MODE" = "status" ]; then
    echo "Staging folder: $STAGING_DIR"
    echo "Files remaining: $TOTAL"
    echo "Batches needed (size $BATCH_SIZE): $(( (TOTAL + BATCH_SIZE - 1) / BATCH_SIZE ))"
    echo ""
    echo "Files:"
    for file in "${FILES[@]}"; do
        echo "  $(basename "$file")"
    done
    exit 0
fi

# All mode
if [ "$MODE" = "all" ]; then
    echo "Deleting all $TOTAL files from staging folder..."
    rm -f "$STAGING_DIR"/*.md
    echo "Done. Click 'Sync Now' in Obsidian Granola plugin settings."
    echo ""
    echo "WARNING: Syncing $TOTAL meetings at once may hit rate limits."
    echo "If you get errors, some meetings will sync and others won't."
    echo "Run 'granola-batch-resync' to re-sync the remainder in batches."
    exit 0
fi

# Batch mode — delete BATCH_SIZE files
DELETE_COUNT=$BATCH_SIZE
if [ "$DELETE_COUNT" -gt "$TOTAL" ]; then
    DELETE_COUNT=$TOTAL
fi

echo "Deleting $DELETE_COUNT of $TOTAL files (batch size: $BATCH_SIZE)..."
echo ""

DELETED=0
for file in "${FILES[@]}"; do
    if [ "$DELETED" -ge "$DELETE_COUNT" ]; then
        break
    fi
    echo "  Removing: $(basename "$file")"
    rm -f "$file"
    DELETED=$((DELETED + 1))
done

REMAINING=$((TOTAL - DELETED))
echo ""
echo "Deleted $DELETED files. $REMAINING remaining."
echo ""
echo "Next steps:"
echo "  1. In Obsidian: click 'Sync Now' in Granola plugin settings"
echo "  2. Wait for sync to complete (check console for rate limit errors)"
echo "  3. Run this script again to process the next batch"
if [ "$REMAINING" -gt 0 ]; then
    echo ""
    echo "Batches remaining: $(( (REMAINING + BATCH_SIZE - 1) / BATCH_SIZE ))"
fi
