#!/bin/bash
# granola-ingest — Transform staged Granola notes into second-brain meeting notes
#
# Usage:
#   granola-ingest              — process all staged Granola notes
#   granola-ingest --dry-run    — preview transformations without writing
#
# Reads staged Granola markdown files from the vault's staging folder (default:
# Granola/), derives meeting frontmatter, creates properly-typed meeting notes
# in 04 Data/YYYY/MM/, and deletes the staging files on success.
#
# Configuration (05 Meta/config.yaml):
#   granola.self_name        — user's own name (excluded from attendee counts)
#   granola.staging_folder   — relative path to staging folder (default: Granola)
#   granola.series_overrides — map of title → meeting_name for edge cases
#
# Environment overrides:
#   SECOND_BRAIN_VAULT  — vault path (default: ~/Documents/obsidian/second-brain)
#   SECOND_BRAIN_NAME   — vault name for Obsidian CLI (default: second-brain)

set -euo pipefail

# ---- Configuration -----------------------------------------------------------

VAULT="${SECOND_BRAIN_VAULT:-$HOME/Documents/obsidian/second-brain}"
VAULT_NAME="${SECOND_BRAIN_NAME:-second-brain}"
CONFIG_FILE="$VAULT/05 Meta/config.yaml"

DRY_RUN=false
if [ "${1:-}" = "--dry-run" ]; then
    DRY_RUN=true
fi

# ---- Helpers -----------------------------------------------------------------

die() {
    echo "ERROR: $*" >&2
    exit 1
}

# Read a scalar value from config.yaml using basic grep/sed (no yq dependency)
# Usage: config_get "granola.self_name"
config_get() {
    local key="$1"
    # Split on dot to handle simple two-level keys
    local section="${key%%.*}"
    local field="${key#*.}"

    if [ "$section" = "$field" ]; then
        # Top-level key
        grep -m1 "^${field}:" "$CONFIG_FILE" 2>/dev/null \
            | sed 's/^[^:]*:[[:space:]]*//' \
            | tr -d '"' \
            || true
    else
        # Two-level key: find section block, then the field within it
        awk -v section="$section" -v field="$field" '
            BEGIN { in_section=0 }
            /^[a-zA-Z]/ { in_section=($0 ~ "^"section":") }
            in_section && $0 ~ "^[[:space:]]+"field":" {
                sub(/^[[:space:]]*[^:]*:[[:space:]]*/, "")
                gsub(/"/, "")
                print
                exit
            }
        ' "$CONFIG_FILE" 2>/dev/null || true
    fi
}

# Parse a frontmatter field from a staged file's content
# Usage: fm_get "granola_id" "$content"
fm_get() {
    local field="$1"
    local content="$2"
    echo "$content" | awk -v f="$field" '
        /^---$/ { count++; next }
        count == 1 && $0 ~ "^"f":" {
            sub(/^[^:]*:[[:space:]]*/, "")
            gsub(/^"/, ""); gsub(/"$/, "")
            print
            exit
        }
        count >= 2 { exit }
    '
}

# Parse the attendees YAML list from frontmatter.
# Handles both inline list and block list formats.
# Returns one attendee per line (names only, wiki-link markup stripped).
fm_get_attendees() {
    local content="$1"
    echo "$content" | awk '
        /^---$/ { count++; next }
        count >= 2 { exit }
        count == 1 && /^attendees:/ {
            # Check for inline list: attendees: [A, B, C]
            if ($0 ~ /\[/) {
                gsub(/^attendees:[[:space:]]*\[/, "")
                gsub(/\].*$/, "")
                n = split($0, parts, /,/)
                for (i=1; i<=n; i++) {
                    val = parts[i]
                    gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
                    gsub(/"/, "", val)
                    if (val != "") print val
                }
            } else {
                # Block list — collect following lines starting with "-"
                in_attendees = 1
            }
            next
        }
        count == 1 && in_attendees && /^[[:space:]]*-[[:space:]]/ {
            val = $0
            gsub(/^[[:space:]]*-[[:space:]]/, "", val)
            gsub(/"/, "", val)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
            print val
            next
        }
        count == 1 && in_attendees && /^[^ ]/ { in_attendees = 0 }
    '
}

# Strip wiki-link markup from an attendee name: [[2026.03.22-alice|Alice Smith]] → Alice Smith
strip_wikilink() {
    echo "$1" | sed 's/\[\[[^|]*|\([^]]*\)\]\]/\1/g; s/\[\[\([^]]*\)\]\]/\1/g'
}

# Convert a title to kebab-case meeting_name:
# 1. Strip trailing date/number patterns
# 2. Lowercase and replace non-alphanumeric runs with hyphens
# 3. Trim leading/trailing hyphens
derive_meeting_name() {
    local title="$1"
    # Strip common trailing patterns (must be tried in decreasing specificity)
    # e.g. " - March 22", " (2026-03-22)", " #5", " v3.2", ordinals like "5th"
    local name="$title"

    # Strip parenthetical dates like (2026-03-22) or (March 22)
    name=$(echo "$name" | sed 's/[[:space:]]*([0-9][^)]*)[[:space:]]*$//g')
    name=$(echo "$name" | sed 's/[[:space:]]*(Jan\|Feb\|Mar\|Apr\|May\|Jun\|Jul\|Aug\|Sep\|Oct\|Nov\|Dec)[^)]*)[[:space:]]*$//g')

    # Strip trailing " - <Month> <day>" or " - <date>"
    name=$(echo "$name" | sed 's/[[:space:]]*-[[:space:]]*[A-Z][a-z][a-z][a-z]*[[:space:]]*[0-9]*[[:space:]]*$//g')
    name=$(echo "$name" | sed 's/[[:space:]]*-[[:space:]]*[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9][[:space:]]*$//g')

    # Strip trailing " #N" (sprint number, episode number, etc.)
    name=$(echo "$name" | sed 's/[[:space:]]*#[0-9][0-9]*[[:space:]]*$//g')

    # Strip trailing version-like suffixes " v<N>" or " v<N.N>"
    name=$(echo "$name" | sed 's/[[:space:]]*v[0-9][0-9.]*[[:space:]]*$//g')

    # Strip trailing ordinals " 5th", " 2nd", etc.
    name=$(echo "$name" | sed 's/[[:space:]]*[0-9][0-9]*\(st\|nd\|rd\|th\)[[:space:]]*$//g')

    # Replace ":" and "/" with space before kebab conversion
    name=$(echo "$name" | tr ':/' '  ')

    # Kebab-case: lowercase, replace runs of non-alphanumeric (except hyphens) with "-"
    name=$(echo "$name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-][^a-z0-9-]*/-/g; s/^-//; s/-$//')

    echo "$name"
}

# Kebab-case a person's name for use in 1on1 meeting names and filenames
kebab_name() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-][^a-z0-9-]*/-/g; s/^-//; s/-$//'
}

# Check if a vault note with the given granola_id already exists.
# Returns the path if found, empty string if not.
find_by_granola_id() {
    local granola_id="$1"
    obsidian "vault=$VAULT_NAME" search "query=granola_id: $granola_id" path="04 Data" format=json 2>/dev/null \
        | grep -o '"path":"[^"]*"' \
        | head -1 \
        | sed 's/"path":"//; s/"//' \
        || true
}

# Read series_overrides from config.yaml as "title|meeting_name" pairs (one per line)
get_series_overrides() {
    awk '
        /^granola:/ { in_granola=1; next }
        in_granola && /^[a-zA-Z]/ && !/^[[:space:]]/ { in_granola=0 }
        in_granola && /series_overrides:/ { in_overrides=1; next }
        in_granola && in_overrides && /^[[:space:]]+[^-]/ {
            # Key: value line under series_overrides
            line = $0
            gsub(/^[[:space:]]+/, "", line)
            # Split on first ": "
            idx = index(line, ": ")
            if (idx > 0) {
                k = substr(line, 1, idx-1)
                v = substr(line, idx+2)
                gsub(/"/, "", k); gsub(/"/, "", v)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", k)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
                print k "|" v
            }
            next
        }
        in_granola && in_overrides && (/^[[:space:]]+[a-zA-Z]/ && !/^[[:space:]]+[a-zA-Z_-]*:/) { in_overrides=0 }
    ' "$CONFIG_FILE" 2>/dev/null || true
}

# Look up series_overrides for the given title. Returns empty if no override.
lookup_series_override() {
    local title="$1"
    get_series_overrides | while IFS='|' read -r key val; do
        if [ "$key" = "$title" ]; then
            echo "$val"
            return
        fi
    done
}

# Extract body (everything after the closing ---) from note content
extract_body() {
    local content="$1"
    echo "$content" | awk '
        /^---$/ { count++; if (count == 2) { found=1; next } }
        found { print }
    '
}

# Generate the collision-avoided target filename in 04 Data/YYYY/MM/
# Returns just the relative path under vault root
generate_target_path() {
    local date="$1"          # YYYY-MM-DD
    local meeting_name="$2"  # kebab-case
    local skip_granola_id="${3:-}"

    local year="${date:0:4}"
    local month="${date:5:2}"
    local date_dots="${year}.${month}.${date:8:2}"
    local base_name="${date_dots}-${meeting_name}"
    local target_dir="04 Data/${year}/${month}"
    local candidate="${target_dir}/${base_name}.md"

    # Check if candidate exists AND has a different granola_id (collision)
    local suffix=1
    while [ -f "$VAULT/$candidate" ]; do
        if [ -n "$skip_granola_id" ]; then
            # If the existing file has the SAME granola_id, this is a dedup case
            existing_content=$(cat "$VAULT/$candidate" 2>/dev/null || true)
            existing_gid=$(fm_get "granola_id" "$existing_content")
            if [ "$existing_gid" = "$skip_granola_id" ]; then
                # Same file — return as-is (caller handles dedup)
                echo "$candidate"
                return
            fi
        fi
        suffix=$((suffix + 1))
        candidate="${target_dir}/${base_name}-${suffix}.md"
    done

    echo "$candidate"
}

# ---- Main processing ---------------------------------------------------------

# Read config
SELF_NAME=$(config_get "granola.self_name")
STAGING_FOLDER=$(config_get "granola.staging_folder")
STAGING_FOLDER="${STAGING_FOLDER:-Granola}"
STAGING_DIR="$VAULT/$STAGING_FOLDER"

# Verify staging folder exists (no-op if missing)
if [ ! -d "$STAGING_DIR" ]; then
    exit 0
fi

# Collect staged .md files
FILES=()
for file in "$STAGING_DIR"/*.md; do
    [ -f "$file" ] || continue
    FILES+=("$file")
done

if [ ${#FILES[@]} -eq 0 ]; then
    exit 0
fi

# Require obsidian CLI for non-dry-run mode
if [ "$DRY_RUN" = false ] && ! command -v obsidian &>/dev/null; then
    die "Obsidian CLI required. Install: https://obsidian.md/cli"
fi

NOW=$(date +"%Y-%m-%d %H:%M")
INGESTED=0
SKIPPED=0
INGESTED_NAMES=()

for file in "${FILES[@]}"; do
    filename=$(basename "$file")
    content=$(cat "$file")

    # --- Parse frontmatter fields ---
    granola_id=$(fm_get "granola_id" "$content")
    title=$(fm_get "title" "$content")
    date=$(fm_get "date" "$content")
    start_time=$(fm_get "start_time" "$content")
    granola_url=$(fm_get "granola_url" "$content")

    if [ -z "$granola_id" ] || [ -z "$title" ] || [ -z "$date" ]; then
        echo "  Skipping $filename — missing required frontmatter (granola_id, title, or date)" >&2
        continue
    fi

    # --- Dedup: skip if vault already has this granola_id ---
    if [ "$DRY_RUN" = false ]; then
        existing=$(find_by_granola_id "$granola_id")
        if [ -n "$existing" ]; then
            echo "  Skipped (already exists): $title [granola_id=$granola_id → $existing]"
            SKIPPED=$((SKIPPED + 1))
            continue
        fi
    fi

    # --- Parse attendees ---
    raw_attendees_list=$(fm_get_attendees "$content")

    # Build array of attendee display names (strip wiki-links)
    ATTENDEE_NAMES=()
    while IFS= read -r raw_att; do
        [ -z "$raw_att" ] && continue
        att_name=$(strip_wikilink "$raw_att")
        ATTENDEE_NAMES+=("$att_name")
    done <<< "$raw_attendees_list"

    # --- Determine meeting_name ---
    # 1. Check series_overrides
    meeting_name=$(lookup_series_override "$title")

    # 2. Check 1-on-1 detection (excluding self)
    OTHER_ATTENDEES=()
    for att in "${ATTENDEE_NAMES[@]}"; do
        [ "$att" = "$SELF_NAME" ] && continue
        OTHER_ATTENDEES+=("$att")
    done

    IS_1ON1=false
    TAGS=()

    if [ ${#OTHER_ATTENDEES[@]} -eq 1 ] && [ -z "$meeting_name" ]; then
        IS_1ON1=true
        TAGS+=("1on1")
        person_kebab=$(kebab_name "${OTHER_ATTENDEES[0]}")
        meeting_name="1on1-${person_kebab}"
    fi

    # 3. Fall back to title normalization
    if [ -z "$meeting_name" ]; then
        meeting_name=$(derive_meeting_name "$title")
    fi

    # --- Generate target path ---
    target_path=$(generate_target_path "$date" "$meeting_name" "$granola_id")

    # Dry-run: just show what would happen
    if [ "$DRY_RUN" = true ]; then
        echo "  [DRY-RUN] $filename"
        echo "    title:        $title"
        echo "    meeting_name: $meeting_name"
        echo "    date:         $date"
        echo "    is_1on1:      $IS_1ON1"
        echo "    target:       $target_path"
        echo "    granola_id:   $granola_id"
        INGESTED=$((INGESTED + 1))
        INGESTED_NAMES+=("$meeting_name")
        continue
    fi

    # --- Build attendees YAML list ---
    ATTENDEES_YAML=""
    for att in "${ATTENDEE_NAMES[@]}"; do
        ATTENDEES_YAML="${ATTENDEES_YAML}  - \"${att}\"\n"
    done

    # --- Build tags YAML list ---
    TAGS_YAML="[]"
    if [ ${#TAGS[@]} -gt 0 ]; then
        TAGS_YAML="[$(IFS=', '; echo "${TAGS[*]}")]"
    fi

    # --- Build aliases ---
    alias_name="$meeting_name"

    # --- Preserve body from staged note ---
    body=$(extract_body "$content")

    # --- Build full note content ---
    year="${date:0:4}"
    month="${date:5:2}"
    day="${date:8:2}"

    note_content="---
type: meeting
meeting_name: \"${meeting_name}\"
date: \"${date}\"
attendees:
$(printf '%b' "$ATTENDEES_YAML")is_1on1: ${IS_1ON1}
granola_id: \"${granola_id}\"
granola_url: \"${granola_url}\"
source: granola
start_time: \"${start_time}\"
tags: ${TAGS_YAML}
aliases:
  - \"${alias_name}\"
created: \"${NOW}\"
modified: \"${NOW}\"
classified_at: \"${NOW}\"
confidence: 1.0
---
${body}"

    # Ensure target directory exists in the vault
    target_dir_full="$VAULT/$(dirname "$target_path")"
    mkdir -p "$target_dir_full"

    # Create the note via Obsidian CLI
    CLI_OUTPUT=$(obsidian "vault=$VAULT_NAME" create "path=$target_path" "content=$note_content" silent 2>&1) || true

    if [ -f "$VAULT/$target_path" ]; then
        rm -f "$file"
        echo "  Ingested: $title → $target_path"
        INGESTED=$((INGESTED + 1))
        INGESTED_NAMES+=("$meeting_name")
    else
        echo "  Failed: $filename — Obsidian CLI error" >&2
        echo "  $CLI_OUTPUT" >&2
    fi
done

# --- Summary output ---
if [ "$DRY_RUN" = true ]; then
    if [ $INGESTED -gt 0 ]; then
        names_joined=$(IFS=', '; echo "${INGESTED_NAMES[*]}")
        echo "Would ingest ${INGESTED} meeting(s): ${names_joined}"
    fi
    exit 0
fi

if [ $INGESTED -gt 0 ]; then
    names_joined=$(IFS=', '; echo "${INGESTED_NAMES[*]}")
    echo "Ingested ${INGESTED} meeting(s): ${names_joined}"
fi
