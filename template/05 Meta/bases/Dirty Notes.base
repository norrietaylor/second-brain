filters:
  and:
    - file.inFolder("04 Data")
    - type != "dailynote"
    - type != "inbox"
formulas:
  is_dirty: if(classified_at && modified, date(modified) > date(classified_at), false)
views:
  - type: table
    name: Dirty Notes
    filters: formula.is_dirty
    order:
      - file.name
      - type
      - modified
      - classified_at
    sort:
      - property: modified
        direction: DESC
