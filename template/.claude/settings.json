{
  "permissions": {
    "allow": [
      "Bash(obsidian *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(python3 *.claude/scripts/*)",
      "Bash(*.claude/scripts/sb*)",
      "Bash(*.claude/scripts/vault-cleanup*)",
      "Bash(*.claude/scripts/gh-fetch*)",
      "Bash(*.claude/scripts/sync-memory.sh*)",
      "Bash(*gh-onmyplate/scripts/*)",
      "Bash(*gl-onmyplate/scripts/*)",
      "Bash(*.claude/scripts/granola-ingest*)",
      "Bash(*.claude/scripts/granola-initial-sync*)",
      "Bash(*.claude/scripts/slack-my-activity*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir -p *)",
      "Bash(chmod +x *)",
      "Bash(command -v *)",
      "Bash(jq *)",
      "Bash(gh *)",
      "Bash(glab *)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 '.claude/scripts/calculate_dates.py'"
          }
        ]
      }
    ]
  }
}
